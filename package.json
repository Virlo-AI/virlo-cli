{
  "name": "virlo-cli",
  "version": "0.1.0",
  "description": "Terminal-native CLI for the Virlo short-form social intelligence API.",
  "type": "module",
  "license": "MIT",
  "author": "Virlo",
  "homepage": "https://dev.virlo.ai",
  "keywords": [
    "virlo",
    "tiktok",
    "youtube-shorts",
    "instagram-reels",
    "social-intelligence",
    "cli",
    "trends"
  ],
  "bin": {
    "virlo": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "virlo": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
